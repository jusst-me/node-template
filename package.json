{
  "name": "node-template",
  "version": "1.0.0",
  "description": "A minimal Node.js template for backend projects (Express, NestJS, etc.)",
  "license": "ISC",
  "author": "Justin van Dijk",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "eslint": "eslint .",
    "prettier": "prettier --check .",
    "format": "prettier --write .",
    "lint": "pnpm run eslint && pnpm run prettier",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-config-jvd": "latest",
    "prettier": "^3.8.1",
    "tsx": "latest",
    "typescript": "latest"
  },
  "prettier": "eslint-config-jvd/prettier"
}
